{
  "_comment": "이 파일을 mcp_config.json으로 복사한 후 환경변수를 실제 값으로 설정하세요",
  "mcpServers": {
    "tavily-mcp": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "DEFAULT_PARAMETERS": "{\"include_answer\": false, \"max_results\": 20, \"search_depth\": \"ultra-fast\"}"
      },
      "description": "웹서치 검색이 필요한 경우 반드시 사용"
    },
    "rag": {
      "command": "python",
      "args": [
        "app/mcp_servers/rag_server.py"
      ],
      "transport": "stdio",
      "description": "사내 문서, 조직문화 문서를 Vector 형태로 보관/조회하는 검색",
      "enabled": true
    },
    "youtube": {
      "command": "python",
      "args": [
        "app/mcp_servers/youtube_tool.py"
      ],
      "transport": "stdio",
      "description": "유튜브 비디오 요약 (제목, 인사이트, 키워드, 타임스탬프별 세그먼트)",
      "enabled": true
    },
    "works_it": {
      "command": "python",
      "args": [
        "app/mcp_servers/works_it_mcp_server.py"
      ],
      "transport": "stdio",
      "description": "IT/보안 지원요청 해결 사례 조회 (LFON WORKS APP VOC 지식베이스)",
      "enabled": true
    },
    "works_acct": {
      "command": "python",
      "args": [
        "app/mcp_servers/works_acct_mcp_server.py"
      ],
      "transport": "stdio",
      "description": "회계/재경 지원요청 해결 사례 조회 (LFON WORKS APP VOC 지식베이스)",
      "enabled": true
    },
    "perplexity": {
      "command": "npx",
      "args": ["-yq", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "PERPLEXITY_TIMEOUT_MS": "300000",
        "PERPLEXITY_LOG_LEVEL": "ERROR"
      },
      "description": "Perplexity AI 기반 웹 검색, 심층 리서치, 추론 도구 (Tavily 비교용)",
      "enabled": false
    },
    "pdf_generator": {
      "command": "python",
      "args": [
        "app/mcp_servers/pdf_generator/server.py"
      ],
      "transport": "stdio",
      "description": "마크다운/텍스트를 PDF로 변환 (테이블 정의서, 보고서, 문서 등)",
      "enabled": true
    },
    "chart_generator": {
      "command": "python",
      "args": [
        "app/mcp_servers/chart_generator/server.py"
      ],
      "transport": "stdio",
      "description": "데이터 시각화 차트 생성 (라인, 막대, 파이, 복합 차트)",
      "enabled": true
    },
    "fetch": {
      "command": "python",
      "args": ["-m", "mcp_server_fetch"],
      "env": {
        "PYTHONIOENCODING": "utf-8"
      },
      "transport": "stdio",
      "description": "웹 페이지 콘텐츠 추출 (HTML → 마크다운 변환)",
      "enabled": true
    }
  }
}
